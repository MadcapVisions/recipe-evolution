{
  "name": "recipe-evolution",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack --hostname 127.0.0.1",
    "dev:turbo": "next dev --turbopack --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start",
    "start:test": "next start --hostname 127.0.0.1 --port 3001",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:unit": "rm -rf .tmp-unit && tsc -p tsconfig.unit.json && node --test .tmp-unit/tests/unit/**/*.test.js",
    "fixtures:export:ai-failures": "node --import tsx scripts/export-ai-failure-fixtures.ts",
    "eval:seed:live": "rm -rf .tmp-eval && tsc -p tsconfig.eval.json && node scripts/test-recipe-gen.mjs",
    "benchmark": "npx tsx --require ./scripts/_mock-server-only.cjs scripts/run-benchmark.ts",
    "benchmark:all": "npx tsx --require ./scripts/_mock-server-only.cjs scripts/run-benchmark.ts --all",
    "e2e": "npm run build && playwright test"
  },
  "dependencies": {
    "@google/generative-ai": "^0.17.0",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@vercel/analytics": "^2.0.1",
    "next": "16.1.6",
    "openai": "^6.27.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
