{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/recipes/[id]/versions/[versionId]",
      "regex": "^/api/recipes/([^/]+?)/versions/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid",
        "nxtPversionId": "nxtPversionId"
      },
      "namedRegex": "^/api/recipes/(?<nxtPid>[^/]+?)/versions/(?<nxtPversionId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/cook/live/[share_slug]",
      "regex": "^/cook/live/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPshare_slug": "nxtPshare_slug"
      },
      "namedRegex": "^/cook/live/(?<nxtPshare_slug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/recipes/[id]",
      "regex": "^/recipes/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/recipes/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/recipes/[id]/new-version",
      "regex": "^/recipes/([^/]+?)/new\\-version(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/recipes/(?<nxtPid>[^/]+?)/new\\-version(?:/)?$"
    },
    {
      "page": "/recipes/[id]/versions/new",
      "regex": "^/recipes/([^/]+?)/versions/new(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/recipes/(?<nxtPid>[^/]+?)/versions/new(?:/)?$"
    },
    {
      "page": "/recipes/[id]/versions/[versionId]",
      "regex": "^/recipes/([^/]+?)/versions/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid",
        "nxtPversionId": "nxtPversionId"
      },
      "namedRegex": "^/recipes/(?<nxtPid>[^/]+?)/versions/(?<nxtPversionId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/recipes/[id]/versions/[versionId]/cook",
      "regex": "^/recipes/([^/]+?)/versions/([^/]+?)/cook(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid",
        "nxtPversionId": "nxtPversionId"
      },
      "namedRegex": "^/recipes/(?<nxtPid>[^/]+?)/versions/(?<nxtPversionId>[^/]+?)/cook(?:/)?$"
    },
    {
      "page": "/recipes/[id]/versions/[versionId]/grocery",
      "regex": "^/recipes/([^/]+?)/versions/([^/]+?)/grocery(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid",
        "nxtPversionId": "nxtPversionId"
      },
      "namedRegex": "^/recipes/(?<nxtPid>[^/]+?)/versions/(?<nxtPversionId>[^/]+?)/grocery(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/api/ai/chef-chat",
      "regex": "^/api/ai/chef\\-chat(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/ai/chef\\-chat(?:/)?$"
    },
    {
      "page": "/api/ai/improve-recipe",
      "regex": "^/api/ai/improve\\-recipe(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/ai/improve\\-recipe(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/import",
      "regex": "^/import(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/import(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/my-recipes",
      "regex": "^/my\\-recipes(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/my\\-recipes(?:/)?$"
    },
    {
      "page": "/new-recipe",
      "regex": "^/new\\-recipe(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/new\\-recipe(?:/)?$"
    },
    {
      "page": "/preferences",
      "regex": "^/preferences(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/preferences(?:/)?$"
    },
    {
      "page": "/recipes/new",
      "regex": "^/recipes/new(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/recipes/new(?:/)?$"
    },
    {
      "page": "/recipes/new/from-text",
      "regex": "^/recipes/new/from\\-text(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/recipes/new/from\\-text(?:/)?$"
    },
    {
      "page": "/sign-in",
      "regex": "^/sign\\-in(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sign\\-in(?:/)?$"
    },
    {
      "page": "/sign-up",
      "regex": "^/sign\\-up(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sign\\-up(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}