{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": ".tmp-unit",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "tests/unit/**/*.ts",
    "lib/ai/cache.ts",
    "lib/recipes/recipeDraft.ts"
  ],
  "exclude": ["node_modules"]
}
